{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowJs": true,
    "checkJs": false,
    "outDir": "./types",
    "rootDir": ".",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "*.js",
    "*.mjs",
    "aggregation/**/*.js",
    "aggregation/**/*.mjs",
    "crudlify/**/*.js",
    "crudlify/**/*.mjs",
    "workflow/**/*.js",
    "workflow/**/*.mjs"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}